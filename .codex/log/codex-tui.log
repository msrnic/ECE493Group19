Invalid retry payload\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/ErrorResponse'\n        '401':\n          description: Session expired or invalid; re-authentication required\n          content:\n            application/json:\n              schema:\n                $ref: '#/components/schemas/AuthRedirectResponse'\ncomponents:\n  schemas:\n    DashboardResponse:\n      type: object\n      required:\n        - actorId\n        - status\n        - modules\n        - sections\n        - retryAvailable\n      properties:\n        actorId:\n          type: integer\n        status:\n          type: string\n          enum: [success, partial, failure, auth_error, empty_access, role_data_error]\n        message:\n          type: string\n        modules:\n          type: array\n          items:\n            $ref: '#/components/schemas/ModuleSummary'\n        sections:\n          type: array\n          items:\n            $ref: '#/components/schemas/SectionState'\n        retryAvailable:\n          type: boolean\n        unavailableSectionIds:\n          type: array\n          items:\n            type: integer\n    ModuleSummary:\n      type: object\n      required:\n        - moduleId\n        - moduleKey\n        - displayName\n        - routePath\n        - navigationState\n      properties:\n        moduleId:\n          type: integer\n        moduleKey:\n          type: string\n        displayName:\n          type: string\n        routePath:\n          type: string\n        navigationState:\n          type: string\n          enum: [enabled, disabled_unavailable]\n    SectionState:\n      type: object\n      required:\n        - sectionId\n        - sectionKey\n        - title\n        - availabilityStatus\n      properties:\n        sectionId:\n          type: integer\n        sectionKey:\n          type: string\n        title:\n          type: string\n        availabilityStatus:\n          type: string\n          enum: [available, unavailable]\n        unavailableLabel:\n          type: string\n          description: Must be present when availabilityStatus is unavailable.\n        content:\n          type: object\n          additionalProperties: true\n    RetryRequest:\n      type: object\n      required:\n        - sectionIds\n      properties:\n        sectionIds:\n          type: array\n          minItems: 1\n          items:\n            type: integer\n      description: Must include only currently unavailable section IDs.\n    AuthRedirectResponse:\n      type: object\n      required:\n        - status\n        - loginUrl\n        - returnTo\n      properties:\n        status:\n          type: string\n          enum: [auth_error]\n        loginUrl:\n          type: string\n          example: /login\n        returnTo:\n          type: string\n          example: /dashboard\n    ErrorResponse:\n      type: object\n      required:\n        - status\n        - errorCode\n        - message\n      properties:\n        status:\n          type: string\n          enum: [error]\n        errorCode:\n          type: string\n        message:\n          type: string\nEOF"} thread_id=019cca7b-dd78-7be3-8ee3-aca0cee54ebd
